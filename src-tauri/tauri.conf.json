{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlickSlax",
  "version": "0.1.0",
  "identifier": "org.slax.slickslax",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SlickSlax",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#0c0f0d"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "The safe Slax USB maker",
    "longDescription": "SlickSlax prepares a Slax USB correctly: MBR, FAT32, the Slax file tree, boot setup, persistence, and verification.",
    "copyright": "Copyright © 2026 SlickSlax contributors",
    "linux": {
      "deb": { "depends": ["udisks2", "parted", "dosfstools", "policykit-1"] },
      "appimage": { "bundleMediaFramework": false }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}

